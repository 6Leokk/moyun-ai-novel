DATABASE_URL=postgres://moyun:moyun@localhost:5432/moyun
JWT_SECRET=change-me-to-a-random-string-at-least-32-chars
ENCRYPTION_KEY=change-me-to-exactly-32-bytes-key!
PORT=3000
DB_POOL_MIN=2
DB_POOL_MAX=20
DB_IDLE_TIMEOUT_MS=30000
LOG_LEVEL=info
NODE_ENV=development
ALLOWED_ORIGINS=http://localhost:5173

# ── SMTP 邮件配置（可选，不配则用 console.log 占位）──
# QQ 邮箱: 登录 mail.qq.com → 设置 → 账户 → 开启 POP3/SMTP 服务 → 获取授权码
# 163 邮箱: smtp.163.com:465
# Resend: smtp.resend.com:587
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=你的QQ号@qq.com
SMTP_PASSWORD=你的QQ邮箱授权码（16位，不是QQ密码）
SMTP_FROM=你的QQ号@qq.com
SMTP_FROM_NAME=墨韵AI
